<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>English Reader</title>

<style>
body {
    font-family: Arial, sans-serif;
    max-width: 900px;
    margin: auto;
    padding: 20px;
    background: #f4f4f4;
}

textarea {
    width: 100%;
    height: 180px;
    margin-bottom: 15px;
    padding: 10px;
    font-size: 16px;
}

button {
    padding: 10px 20px;
    font-size: 16px;
    cursor: pointer;
}

#result {
    margin-top: 25px;
    padding: 20px;
    background: white;
    border-radius: 10px;
    line-height: 2;
    font-size: 20px;
}

.word {
    color: #1565c0;
    font-weight: bold;
    cursor: pointer;
}

.word:hover {
    text-decoration: underline;
}

#knownWords {
    margin-top: 20px;
    font-size: 14px;
}
</style>
</head>

<body>

<h2>English Reader</h2>

<p>Английский текст:</p>
<textarea id="english"></textarea>

<p>Русский перевод:</p>
<textarea id="russian"></textarea>

<button onclick="buildText()">Создать текст</button>

<div id="result"></div>

<div id="knownWords"></div>

<script>

let known = JSON.parse(localStorage.getItem("knownWords")) || [];

function buildText() {

    let eng = document.getElementById("english").value
        .split(/\s+/);

    let rus = document.getElementById("russian").value
        .split(/\s+/);

    let output = "";

    for (let i = 0; i < rus.length; i++) {

        let englishWord = eng[i];

        if (!englishWord) {
            output += rus[i] + " ";
            continue;
        }

        let clean = englishWord
            .toLowerCase()
            .replace(/[^a-z']/g, "");

        if (known.includes(clean)) {
            output += `<span class="word"
                      onclick="learn('${clean}')">
                      ${englishWord}</span> `;
        } else {
            output += rus[i] + " ";
        }
    }

    document.getElementById("result").innerHTML = output;

    showKnown();
}

function learn(word) {

    if (!known.includes(word)) {
        known.push(word);
    }

    localStorage.setItem(
        "knownWords",
        JSON.stringify(known)
    );

    buildText();
}

function showKnown() {
    document.getElementById("knownWords").innerHTML =
        "<b>Изученные слова:</b><br>" +
        known.join(", ");
}

showKnown();

</script>

</body>
</html>
